# =============================================================================
# TiDB Unified Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================


# ── LLM Provider ──────────────────────────────────────────────────────────────
# Uncomment and set the key for whichever provider you are using.
# The agent currently uses the Anthropic SDK — swap the client in agent_ui.py
# and run_agent.py to switch providers.

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GOOGLE_API_KEY=AIza...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/


# ── TiDB Cloud ────────────────────────────────────────────────────────────────
# Get these from your TiDB Cloud console under Connect → Python:
# https://tidbcloud.com

TIDB_HOST=gateway01.<region>.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=<your-cluster-prefix>.root
TIDB_PASSWORD=<your-password>
TIDB_DATABASE=test

# Path to the TiDB CA certificate (download from TiDB Cloud console)
# macOS:  /Users/<you>/Downloads/isrgrootx1.pem
# Linux:  /home/<you>/isrgrootx1.pem
TIDB_SSL_CA=/path/to/isrgrootx1.pem
